# Environment Variables Configuration
# Copy this file to .env.local and update with your values
# Never commit .env.local to version control

# Backend API Base URL
# NEXT_PUBLIC_ prefix makes this available in the browser
# Update this with your actual backend API URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/

# Tally Mock Server URL (for development/testing)
# This is used by the Receipt Voucher form to fetch account balances
NEXT_PUBLIC_TALLY_MOCK_URL=http://localhost:5001

# Node environment (development, production, test)
NODE_ENV=development
